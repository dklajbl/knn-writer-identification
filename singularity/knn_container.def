Bootstrap: docker
From: pytorch/pytorch:2.10.0-cuda13.0-cudnn9-runtime

%files
    {{REQUIREMENTS_FILE}} /opt/requirements.txt

%post
    # Exit immediately if a command exits with a non-zero status
    set -e

    # Update and install necessary system packages
    apt-get update && apt-get install -y --no-install-recommends \
        build-essential \
        python3-dev \
        python3-venv \
        python3-pip

    # create Python venv
    python3 -m venv /opt/venv

    # Upgrade pip
    /opt/venv/bin/pip install --upgrade pip

    # Install required python packages
    /opt/venv/bin/pip install --no-cache-dir -r /opt/requirements.txt

    # Clean up cache to reduce container size
    apt-get autoremove -y
    apt-get clean
    rm -rf /root/.cache
    rm -rf /var/lib/apt/lists/*

%environment
    # Set environment variables
    export PYTHONPATH=/workspace
    # export PATH=/usr/local/bin:$PATH
    # adding path to venv to PATH -> calling python3 will resolve to the venv interpreter
    export PATH=/opt/venv/bin:$PATH
    export CUDA_HOME=/usr/local/cuda-13.0

%runscript
    # Script that is executed when using command:
    #   singularity run --nv -B $PWD:/workspace container.sif train.py

    cd /workspace
    exec python3 "$@"
